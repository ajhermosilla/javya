# =========================
# Javya Environment Variables
# =========================
# Copy this file to .env and fill in your values
# cp .env.example .env

# =========================
# Database (PostgreSQL)
# =========================
POSTGRES_USER=javya
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=javya
DATABASE_URL=postgresql+asyncpg://javya:change_me_in_production@db:5432/javya

# =========================
# Backend (FastAPI)
# =========================
BACKEND_PORT=8000
DEBUG=true
SECRET_KEY=generate_a_random_secret_key_here

# CORS - comma-separated origins allowed
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =========================
# Frontend (React)
# =========================
# Leave empty for dev (Vite proxy handles /api → backend).
# Set to full URL in production (e.g. https://javya.example.com/api/v1).
VITE_API_URL=
VITE_DEFAULT_LANGUAGE=en
